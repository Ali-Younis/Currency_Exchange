JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=8h

# CORS: the origin allowed to call the API.
# In production with nginx on port 80, set to your domain.
# In development (no nginx), use http://localhost:3000.
CORS_ORIGIN=http://localhost:3000

# Internal URL of the NestJS API as seen from INSIDE the Docker network.
# Used by Next.js server rewrites at runtime — never reaches the browser.
# This replaces the old NEXT_PUBLIC_API_URL (which was baked at build time).
API_INTERNAL_URL=http://api:3001
