// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  TELLER
}

enum TransactionType {
  BUY   // Agency buys foreign currency FROM customer (currencyOut = GBP)
  SELL  // Agency sells foreign currency TO customer  (currencyIn  = GBP)
  CROSS // Non-GBP to non-GBP exchange via GBP bridge
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  username            String    @unique
  passwordHash        String
  fullName            String
  receiptAlias        String?
  email               String?   @unique
  role                Role      @default(TELLER)
  isActive            Boolean   @default(true)
  forcePasswordChange Boolean   @default(false)
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
  permissions         Json      @default("[]")
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  transactions   Transaction[]
  openingBals    OpeningBalance[]
  exchangeRates  ExchangeRate[]
  auditLogs      AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// CURRENCIES
// ─────────────────────────────────────────────

model Currency {
  id          String  @id @default(uuid())
  code        String  @unique  // e.g. "USD", "GBP"
  nameEn      String           // e.g. "US Dollar"
  nameAr      String           // e.g. "دولار أمريكي"
  symbol      String           // e.g. "$"
  countryCode String?  @db.VarChar(2)  // ISO 3166-1 alpha-2 e.g. "US", "GB"
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  openingBals         OpeningBalance[]
  exchangeRatesAsCcy  ExchangeRate[]   @relation("ExchangeRateCurrency")
  transactionsIn      Transaction[]    @relation("CurrencyIn")
  transactionsOut     Transaction[]    @relation("CurrencyOut")

  @@map("currencies")
}

// ─────────────────────────────────────────────
// EXCHANGE RATES
// Admin sets buy/sell rates for each currency per session/day.
// Base currency is GBP (ISO 4217: 826).
// Convention: rates are expressed as "foreign units per 1 GBP".
// buyRate  = agency's rate when BUYING foreign from customer (HIGHER — fewer GBP given)
//            Formula: GBP out = foreign in  / buyRate
// sellRate = agency's rate when SELLING foreign to customer (LOWER — less foreign given)
//            Formula: foreign out = GBP in × sellRate
// Invariant: buyRate > sellRate → spread = buyRate - sellRate > 0 = bureau profit
// ─────────────────────────────────────────────

model ExchangeRate {
  id         String   @id @default(uuid())
  currency   Currency @relation("ExchangeRateCurrency", fields: [currencyId], references: [id])
  currencyId String
  buyRate    Decimal  @db.Decimal(18, 6)  // How many units of foreign currency per 1 GBP (agency buys)
  sellRate   Decimal  @db.Decimal(18, 6)  // How many units of foreign currency per 1 GBP (agency sells)
  effectiveDate DateTime @default(now())
  setBy      User     @relation(fields: [setById], references: [id])
  setById    String
  createdAt  DateTime @default(now())

  @@index([currencyId, effectiveDate])
  @@map("exchange_rates")
}

// ─────────────────────────────────────────────
// OPENING BALANCES (رصيد بداية المدة)
// Recorded once per session/day per currency by Admin.
// ─────────────────────────────────────────────

model OpeningBalance {
  id         String   @id @default(uuid())
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId String
  amount     Decimal  @db.Decimal(18, 2)
  sessionDate DateTime @db.Date           // Date of the session (no time component)
  setBy      User     @relation(fields: [setById], references: [id])
  setById    String
  createdAt  DateTime @default(now())

  @@unique([currencyId, sessionDate])     // One opening balance per currency per day
  @@index([sessionDate])
  @@map("opening_balances")
}

// ─────────────────────────────────────────────
// TRANSACTIONS
// ─────────────────────────────────────────────

model Transaction {
  id              String          @id @default(uuid())
  receiptNumber   String          @unique  // Human-readable serial ID, e.g. TXN-2026-00001
  type            TransactionType
  customerName    String
  customerEmail   String?         @db.VarChar(255)
  currencyIn      Currency        @relation("CurrencyIn",  fields: [currencyInId],  references: [id])
  currencyInId    String
  amountIn        Decimal         @db.Decimal(18, 2)
  currencyOut     Currency        @relation("CurrencyOut", fields: [currencyOutId], references: [id])
  currencyOutId   String
  amountOut       Decimal         @db.Decimal(18, 2)
  rateApplied     Decimal         @db.Decimal(18, 6)   // Snapshot of rate used at time of transaction
  valueInGbp      Decimal         @db.Decimal(18, 2)   // Total value converted to GBP for accounting
  // ── Profit snapshot fields (filled on every transaction create) ────────────
  buyRateSnapshot  Decimal?       @db.Decimal(18, 6)   // Buy rate in effect when transaction was created
  sellRateSnapshot Decimal?       @db.Decimal(18, 6)   // Sell rate in effect when transaction was created
  spreadProfitGbp  Decimal?       @db.Decimal(18, 4)   // Estimated spread profit in GBP for this transaction
  commission1     Decimal?        @db.Decimal(18, 2)   // Commission on leg 1 (stored in GBP)
  commission2     Decimal?        @db.Decimal(18, 2)   // Commission on leg 2 for CROSS transactions
  notes           String?
  isVoided        Boolean         @default(false)
  voidedAt        DateTime?
  voidedReason    String?
  teller          User            @relation(fields: [tellerId], references: [id])
  tellerId        String
  createdAt       DateTime        @default(now())
  sessionDate     DateTime        @db.Date             // The business date of this transaction

  @@index([sessionDate])
  @@index([tellerId])
  @@index([type])
  @@map("transactions")
}

// ─────────────────────────────────────────────
// AUDIT LOG (Immutable — no updates/deletes)
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // e.g. "LOGIN", "CREATE_TRANSACTION", "VOID_TRANSACTION", "SET_RATE"
  entity     String?  // e.g. "Transaction", "ExchangeRate"
  entityId   String?
  ipAddress  String?
  userAgent  String?
  payload    Json?    // Full before/after snapshot of changed data
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// APP SETTINGS (key-value store for runtime config)
// ─────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
