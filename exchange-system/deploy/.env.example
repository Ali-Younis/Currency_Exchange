# ─────────────────────────────────────────────────────────────────────────────
# Exchange Manager — Environment Configuration
# Copy this file to .env and fill in the values marked with <...>
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub Container Registry ─────────────────────────────────────────────────
# Your GitHub username (lowercase). Images will be pulled from:
#   ghcr.io/<GITHUB_OWNER>/exchange-api:latest
#   ghcr.io/<GITHUB_OWNER>/exchange-web:latest
GITHUB_OWNER=<your_github_username>

# Specific image version to deploy. Use "latest" for the most recent build,
# or a short SHA tag (e.g. sha-a1b2c3d) to pin a specific release.
IMAGE_TAG=latest

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=exchange_user
POSTGRES_PASSWORD=<choose_a_strong_password>
POSTGRES_DB=exchange_db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 48
JWT_SECRET=<generate_a_random_64_char_string>
JWT_EXPIRES_IN=8h

# ── Network ───────────────────────────────────────────────────────────────────
# Port exposed on the host. Change to 443 if you terminate TLS at this container.
HTTP_PORT=80

# Allowed CORS origin. Set to the public URL your users open in their browser.
# Examples:
#   http://192.168.1.50        (LAN IP, no domain)
#   https://exchange.mycompany.com   (with a domain + TLS upstream)
CORS_ORIGIN=http://localhost
